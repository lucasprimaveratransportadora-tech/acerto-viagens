# Banco de dados (Railway gera automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=trocar-por-string-aleatoria-de-48-caracteres-minimo
JWT_REFRESH_SECRET=trocar-por-outra-string-aleatoria-diferente

# Servidor
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Seguranca
BCRYPT_ROUNDS=12

# Admin inicial (usado no seed)
ADMIN_EMAIL=admin@prima.com.br
ADMIN_SENHA=trocar-senha-forte
ADMIN_NOME=Administrador
EMPRESA_NOME=Prima Transportadora
EMPRESA_CNPJ=00.000.000/0001-00

# Cloudflare R2 (anexos) - configurar quando ativar uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=prima-anexos
R2_PUBLIC_URL=
